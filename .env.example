# Reddit API Credentials (optional unless using authenticated mode)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Reddit User Credentials (optional, for posting/commenting)
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Authentication Mode (optional, defaults to 'auto')
# auto         - Use OAuth if credentials exist, fallback to anonymous (default)
# authenticated - Require OAuth, fail if no credentials
# anonymous    - Always use public JSON API (no auth, ~10 req/min)
REDDIT_AUTH_MODE=auto

# Transport Configuration
# TRANSPORT_TYPE=stdio  # Uncomment for stdio mode (default: httpStream for direct node execution, stdio for npx/bin)
PORT=3000               # HTTP server port (default: 3000, only used when TRANSPORT_TYPE is httpStream or not set)
# HOST=0.0.0.0          # HTTP server host (default: 0.0.0.0, binds to all interfaces for Docker)

# OAuth Settings for HTTP Server (optional)
OAUTH_ENABLED=false
OAUTH_TOKEN=

# ─────────────────────────── Facebook (groups + pages) ───────────────────────────
# EASIEST: don't set anything here — just run `pnpm run setup`, which auto-grabs your
# Facebook login from your browser and fills in FACEBOOK_COOKIE for you.
#
# Or let the server auto-read cookies from a logged-in browser on every start:
# FACEBOOK_COOKIE_FROM=chrome           # chrome | brave | edge | arc | chromium | vivaldi | opera
# FACEBOOK_COOKIE_FROM_PROFILE=Default  # browser profile name
#
# Or paste the session cookie manually (whole Cookie header; needs c_user + xs).
# Treat these as secrets.
FACEBOOK_COOKIE=
# Alternatively, provide cookie parts individually:
# FACEBOOK_C_USER=
# FACEBOOK_XS=
# FACEBOOK_DATR=

# Scraping engine: auto (default), http (lightweight fetch), browser (Playwright).
# The browser engine is the most reliable for private groups + full comment threads.
# Install it once with: npm install playwright && npx playwright install chromium
FACEBOOK_ENGINE=auto
# FACEBOOK_HEADLESS=true          # Run the browser engine headless (true/false)
# FACEBOOK_MIN_DELAY_MS=4000      # Min delay between Facebook requests (anti-bot pacing)
# FACEBOOK_LOCALE=en_US           # Preferred locale
# FACEBOOK_USER_AGENT=            # Override the User-Agent
# FACEBOOK_CACHE=on               # In-memory response cache (on/off)
# FACEBOOK_CACHE_MAX_MB=50        # Cache size cap in MB
